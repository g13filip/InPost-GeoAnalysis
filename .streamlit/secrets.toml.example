# Na Streamlit Cloud wklej zawartość w: Settings → Secrets
#
# Top-level klucze są automatycznie dostępne jako zmienne środowiskowe
# (os.getenv), więc działają zarówno w Streamlit jak i w kodzie pipeline'u.

# ── API InPost ────────────────────────────────────────────────────────────────
INPOST_API_BASE = ""

# ── tryb aplikacji ────────────────────────────────────────────────────────────
# "0" = tylko podgląd map (Streamlit Cloud)
# "1" = pełna wersja z pipeline'm (lokalnie)
PIPELINE_ENABLED = "0"
